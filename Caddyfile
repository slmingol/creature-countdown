:80 {
	root * /usr/share/caddy
	file_server
	
	# Enable gzip compression
	encode gzip
	
	# Set cache headers for static assets
	@static {
		path *.css *.js *.png *.jpg *.jpeg *.gif *.svg *.ico
	}
	header @static Cache-Control "public, max-age=31536000"
	
	# Enable access logging
	log {
		output stdout
		format json
	}
}
