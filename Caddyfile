:80 {
	root * /usr/share/caddy
	file_server
	
	# Enable gzip compression
	encode gzip
	
	# Disable caching for HTML, CSS, and JS files (for easier updates)
	@nocache {
		path *.html *.css *.js
	}
	header @nocache Cache-Control "no-cache, no-store, must-revalidate"
	header @nocache Pragma "no-cache"
	header @nocache Expires "0"
	
	# Cache images for 1 day
	@images {
		path *.png *.jpg *.jpeg *.gif *.svg *.ico
	}
	header @images Cache-Control "public, max-age=86400"
	
	# Enable access logging
	log {
		output stdout
		format json
	}
}
